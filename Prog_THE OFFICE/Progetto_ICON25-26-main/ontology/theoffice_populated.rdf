<owl:Class rdf:about="#Episodio_eccellente">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Episodio"/>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <owl:Restriction>
              <owl:onProperty rdf:resource="#haEvento"/>
              <owl:someValuesFrom rdf:resource="#Addio_Personaggio"/>
            </owl:Restriction>
            <owl:Restriction>
              <owl:onProperty rdf:resource="#haEvento"/>
              <owl:someValuesFrom rdf:resource="#Matrimonio"/>
            </owl:Restriction>
            <owl:Restriction>
              <owl:onProperty rdf:resource="#haOggetto"/>
              <owl:someValuesFrom rdf:resource="#Premio_Dundie"/>
            </owl:Restriction>
          </owl:unionOf>
        </owl:Class>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#Episodio"/>
</owl:Class>

